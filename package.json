  "description": "Operator-facing Treeseed CLI package.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/treeseed-ai/cli.git",
    "directory": "."
  },
  "homepage": "https://treeseed.dev",
  "bugs": {
    "url": "https://github.com/treeseed-ai/cli/issues"
  },
  "packageManager": "npm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "scripts/verify-driver.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "setup": "npm install",
    "setup:ci": "npm ci",
    "build": "npm run build:dist",
    "lint": "npm run build:dist",
    "test": "npm run build:dist && node --import tsx --test --test-concurrency=1 ./scripts/treeseed-help.test.ts ./scripts/scene-command.test.ts ./scripts/guarantees-command.test.ts ./scripts/seed.test.ts ./scripts/projects-deploy.test.ts ./scripts/wrapper-package.test.ts ./scripts/hosting-command.test.ts ./scripts/ready-command.test.ts ./scripts/operations-smoke.test.ts ./scripts/reconcile-command.test.ts ./scripts/runtime-cwd.test.ts ./scripts/stage-output.test.ts ./scripts/secrets-escrow.test.ts",
    "build:dist": "node --import tsx ./scripts/build-dist.ts",
    "prepare": "node --import tsx ./scripts/prepare.ts",
    "prepack": "npm run build:dist",
    "verify:direct": "npm run release:verify",
    "verify:local": "TREESEED_VERIFY_DRIVER=direct TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "verify:action": "TREESEED_VERIFY_DRIVER=act TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "verify": "TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "release:setup": "npm run setup:ci",
    "release:check-tag": "node --import tsx ./scripts/assert-release-tag-version.ts",
    "release:verify": "node --import tsx ./scripts/release-verify.ts",
    "release:publish": "node --import tsx ./scripts/publish-package.ts"
  },
  "dependencies": {
    "@treeseed/agent": "github:treeseed-ai/agent#175239efa3c021609bf31a62e3f4942a57fb418c",
    "@treeseed/core": "github:treeseed-ai/core#5600aef506d16d898d50dd56f087e8c764ef2d4e",
    "@treeseed/sdk": "github:treeseed-ai/sdk#abad2591a570a3d04041f6e7f28a21c23192591a",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "bin": {
    "treeseed": "./dist/cli/main.js",
    "trsd": "./dist/cli/main.js"
  }
}

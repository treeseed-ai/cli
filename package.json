    "test": "npm run build:dist && node --import tsx --test --test-concurrency=1 ./scripts/treeseed-help.test.ts ./scripts/scene-command.test.ts ./scripts/guarantees-command.test.ts ./scripts/seed.test.ts ./scripts/projects-deploy.test.ts ./scripts/wrapper-package.test.ts ./scripts/hosting-command.test.ts ./scripts/ready-command.test.ts ./scripts/operations-smoke.test.ts ./scripts/reconcile-command.test.ts ./scripts/runtime-cwd.test.ts ./scripts/stage-output.test.ts ./scripts/secrets-escrow.test.ts ./scripts/dev-lifecycle.test.ts ./scripts/capacity-output-security.test.ts ./scripts/capacity-forensics.test.ts ./scripts/capacity-governance-confirmation.test.ts ./scripts/capacity-checkpoint-integration.test.ts ./scripts/capacity-operator-parity.test.ts ./scripts/capacity-workday-provider.test.ts ./scripts/capacity-workday-agent-class.test.ts ./scripts/capacity-workday-summary.test.ts ./scripts/capacity-workday-treedx.test.ts ./scripts/operations-registry-options.test.ts",

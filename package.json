{
  "name": "@treeseed/cli",
  "version": "0.2.0",
  "description": "Operator-facing Treeseed CLI package.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/treeseed-ai/cli.git",
    "directory": "."
  },
  "homepage": "https://treeseed.ai",
  "bugs": {
    "url": "https://github.com/treeseed-ai/cli/issues"
  },
  "packageManager": "npm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "setup": "npm install",
    "setup:ci": "npm ci",
    "build": "npm run build:dist",
    "test": "TREESEED_TEMPLATE_CATALOG_URL=file:./src/template-catalog/catalog.fixture.json npm run test:templates && npm run build:dist && node --test ./scripts/*.test.mjs",
    "test:templates": "TREESEED_TEMPLATE_CATALOG_URL=file:./src/template-catalog/catalog.fixture.json node ./scripts/run-ts.mjs ./scripts/validate-templates.ts",
    "build:dist": "node ./scripts/run-ts.mjs ./scripts/build-dist.ts",
    "prepack": "npm run build:dist",
    "test:scaffold": "TREESEED_TEMPLATE_CATALOG_URL=file:./src/template-catalog/catalog.fixture.json node ./scripts/run-ts.mjs ./scripts/test-scaffold.ts",
    "release:setup": "npm run setup:ci",
    "release:check-tag": "node ./scripts/run-ts.mjs ./scripts/assert-release-tag-version.ts",
    "release:verify": "node ./scripts/run-ts.mjs ./scripts/release-verify.ts",
    "release:publish": "node ./scripts/run-ts.mjs ./scripts/publish-package.ts"
  },
  "dependencies": {
    "@treeseed/agent": "^0.1.2",
    "@treeseed/core": "^0.1.2",
    "@treeseed/sdk": "^0.1.2",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0"
  },
  "bin": {
    "treeseed": "./dist/cli/main.js"
  }
}

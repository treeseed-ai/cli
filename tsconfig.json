{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/index.ts",
    "src/cli/main.ts",
    "src/cli/runtime.ts",
    "src/cli/help.ts",
    "src/cli/parser.ts",
    "src/cli/registry.ts",
    "src/cli/types.ts"
  ]
}
